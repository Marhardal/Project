<div class="card h-100 border-0 shadow-sm rounded-3">
    <ul class="list-group list-group-flush">
         <li class="list-group-item">
        <div class="d-flex justify-content-between align-items-start">
            <div class="d-flex align-items-center gap-2">
                <div class="p-2 rounded bg-body-secondary">
                    <i class="@getProjectType(Title) fs-6"></i>
                </div>
            </div>

            <h6 class="mb-0 fw-semibold p-2">@Title</h6>
        </div>
        </li>
         <li class="list-group-item">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <small class="text-muted">Total</small>
            <small class="fw-semibold">@Info</small>
        </div>
        </li>
         <li class="list-group-item">
        <div class="progress-stacked my-2" >
            @if (Data is not null && Data.Count > 0)
            {
                @for (var i = 0; i < Data.Count; i++)
                {
                    var value = Data[i];
                    var percent = total > 0 ? (int)Math.Round((value * 100.0) / total) : 0;
                    var color = GetColor(i);

                    <div class="progress"
                         role="progressbar"
                         aria-label="Segment @((i + 1).ToString())"
                         aria-valuenow="@percent"
                         aria-valuemin="0"
                         aria-valuemax="100"
                         style="width: @percent%">
                        <div class="progress-bar" style="background-color:@color"></div>
                    </div>
                }
            }
        </div>
        <div class="mt-3">
            @if (Data is not null)
            {
                @for (var i = 0; i < Math.Min(Data.Count, 5); i++)
                {
                    var percent = total > 0 ? (int)Math.Round((Data[i] * 100.0) / total) : 0;
                    var color = GetColor(i);
                    var name = GetStatus(i);

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <StatusItem Colour="@color" Name="@name" />

                        <span class="fw-semibold small">@percent%</span>
                    </div>
                }
            }
        </div>
        </li>
    </ul>
</div>

@code {
    [Parameter]
    public required string Title { get; set; }

    [Parameter]
    public required string Info { get; set; }

    [Parameter]
    public required string Icon { get; set; }

    [Parameter]
    public IReadOnlyList<int> Data { get; set; } = Array.Empty<int>();

    [Parameter]
    public IReadOnlyList<string>? Colors { get; set; }

    [Parameter]
    public IReadOnlyList<string>? Status { get; set; }

    private int total => Data?.Sum() ?? 0;

    private string GetColor(int index)
    {
        if (Colors is null || Colors.Count == 0)
            return "";

        // Colors are expected to be CSS/hex colors (e.g. "#198754" or "198754").
        return index < Colors.Count ? NormalizeColor(Colors[index]) : "";
    }

    private string GetStatus(int index)
    {
        if (Status is null || Status.Count == 0)
            return "";

        return index < Status.Count ? Status[index] : "";
    }

    private static string NormalizeColor(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
            return string.Empty;

        // Accept either "#RRGGBB" / "#RGB" or "RRGGBB" / "RGB".
        if (color.StartsWith("#", StringComparison.Ordinal))
            return color;

        return $"#{color}";
    }

    private static string getProjectType(string? type)
    {
        if (string.IsNullOrWhiteSpace(type))
            return string.Empty;
        string icon = string.Empty;
        // Accept either "#RRGGBB" / "#RGB" or "RRGGBB" / "RGB".
        if (!string.IsNullOrEmpty(type))
        {
            switch (type)
            {
                case "Proposal":
                    icon = "bi bi-file-earmark-pdf-fill";
                    break;
                case "ESIA":
                    icon = "bi bi-globe-europe-africa";
                    break;
                case "Audit":
                    icon = "bi bi-search";
                    break;
                case "ESMP":
                    icon = "bi bi-cone-striped";
                    break;
                default:
                    icon = type;
                    break;
            }
        }
        // return type;

        return $"#{icon}";
    }
}


