        <h6 class="mb-1">@Title</h6>
        <p class="card-text mb-0">@Info</p>
    </div>
    <div class="p-2">
        <div class="row">
            <div class="col-4">
                <i class="@Icon me-2" style="font-size: 1rem;"></i>
                <span>15%</span>
            </div>
            <div class="col-4">
                <i class="@Icon me-2" style="font-size: 1rem;"></i>
