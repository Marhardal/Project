        pointer-events: none;
        min-width: 140px;
    }

    .legend {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 8px;
        font-size: 0.8rem;
        color: #555;
    }

    .legend-gradient {
        width: 180px;
        height: 14px;
        border-radius: 4px;
        background: linear-gradient(to right, rgb(0,150,0), rgb(0,40,0));
    }

    .district-card {
    position: absolute;
    background: white;
    border: 1px solid #ddd;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    min-width: 180px;
    max-width: 220px;
    pointer-events: none;
    z-index: 10;
    overflow: hidden;
    }

    .district-card {
        position: absolute;
        background: white;
        border: 1px solid #ddd;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        min-width: 180px;
