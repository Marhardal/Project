@* <div class="col-md-4 col-sm-12 mt-sm-2"> *@
    @* <div class="card">
        <div class="card-header">
            <div class="row">
                <div class="col-8">
                    <div class="card-title">Project Distribution</div>
                </div>
                <div class="col-4 text-end">
                    <NavLink class="btn btn-sm btn-outline-primary" href="Project/Status">View</NavLink>
                </div>
            </div>
        </div>
        <div class="card-body"> *@

            @if (_loading)
            {
                <p>Loading map...</p>
            }
            else
            {

    <div class="map-wrapper" id="mapWrapper">
        <svg viewBox="0 0 1000 1000" width="600" height="600" xmlns="http://www.w3.org/2000/svg"
     stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width=".5">

            @foreach (var d in _districts)
            {
                <path id="@d.Code" d="@d.PathData" fill="@GetColor(d.Code)"
                      @onmouseover="() => _hovered = d"
                      @onmouseout="() => _hovered = null"
                      @onmousemove="async (e) => await UpdateMousePosition(e)"
                      style="cursor:pointer">
                    @* <title>@d.Name — @GetTotal(d.Code) projects</title> *@
                </path>
            }
        </svg>
        @if (_hovered != null)
        {
            var distData = Distributions?.FirstOrDefault(d => d.Code == _hovered.Code);

            <div class="district-card" style="left:@CardLeft; top:@CardTop;">
                <div class="district-card-header">
                    <strong>@_hovered.Name</strong>
                    <span class="badge" style="background-color: @GetColor(_hovered.Code);">
                        @GetTotal(_hovered.Code) total
                    </span>
                </div>

                @if (distData?.Project != null && distData.Project.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var project in distData.Project)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@((ProjectType)project.Type)</span>
                                <span class="text-dark">@project.Total</span>
                            </li>
                        }
                    </ul>
                }
                @* else
                {
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item text-muted">No projects</li>
                    </ul>
                } *@
            </div>
        }
        <div class="legend">
            <span>0</span>
            <div class="legend-gradient"></div>
            <span>@_max</span>
        </div>
    </div>
            }
    @*     </div>
    </div> *@
@* </div> *@

@code {
    // ── State ────────────────────────────────────────────────
    bool _loading = true;
    DistrictEntry? _hovered;
    Dictionary<string, int> _totals = new();
    int _max = 1;
    List<DistrictEntry> _districts = new();
    double _mouseX;
    double _mouseY;

    // ── Models ───────────────────────────────────────────────
    record ApiResult(string District, int Total, string Code);
    record DistrictEntry(string Code, string Name, string PathData);

    [Parameter]
    public required DateTime? StartDate { get; set; }

    [Parameter]
    public required DateTime? EndDate { get; set; }

    [Parameter]
    public required List<DistrictDistribution>? Distributions { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadMapAsync();
    }

    double _wrapperWidth;
    double _wrapperHeight;
    const double CardWidth = 220;
    const double CardHeight = 150;

    string CardLeft => (_mouseX + CardWidth + 15) > _wrapperWidth
        ? $"{_mouseX - CardWidth - 10}px"
        : $"{_mouseX + 15}px";

    string CardTop => (_mouseY + CardHeight + 15) > _wrapperHeight
        ? $"{_mouseY - CardHeight - 10}px"
        : $"{_mouseY + 15}px";

    async Task UpdateMousePosition(MouseEventArgs e)
    {
        try
        {
            var pos = await JSRuntime.InvokeAsync<MousePosition>(
                "mapHelper.getMousePosition",
                "mapWrapper",  // we'll use document.getElementById
                e.ClientX,
                e.ClientY
            );

            _mouseX = pos.X;
            _mouseY = pos.Y;
            _wrapperWidth = pos.WrapperWidth;
            _wrapperHeight = pos.WrapperHeight;
        }
        catch { }
    }

    record MousePosition(double X, double Y, double WrapperWidth, double WrapperHeight);

    private async Task LoadMapAsync()
    {
        _loading = true;
        StateHasChanged();

        _districts.Clear();

        var svgTask = Http.GetStringAsync(navigationManager.BaseUri + "Maps/mw.svg");
        var districtsTask = LocationService.GetLocationsAsync();
        var resultsTask = HomeService.GetDistrictDistribution(StartDate, EndDate);

        await Task.WhenAll(svgTask, districtsTask, resultsTask);

        var dbDistricts = ((await districtsTask) ?? new())
            .Where(d => !string.IsNullOrWhiteSpace(d.Code))
            .ToDictionary(d => d.Code);

        Distributions = (await resultsTask) ?? new();

        var doc = new System.Xml.XmlDocument();
        doc.LoadXml(await svgTask);

        foreach (System.Xml.XmlNode node in doc.GetElementsByTagName("path"))
        {
            var id = node.Attributes?["id"]?.Value;
            var d = node.Attributes?["d"]?.Value;

            if (string.IsNullOrWhiteSpace(id) ||
                string.IsNullOrWhiteSpace(d) ||
                !id.StartsWith("MW"))
            {
                continue;
            }

            var name = dbDistricts.TryGetValue(id, out var db)
                ? db.Location
                : node.Attributes?["name"]?.Value ?? id;

            _districts.Add(new DistrictEntry(id, name, d));
        }

        _totals = Distributions
            .Where(r => !string.IsNullOrWhiteSpace(r.Code))
            .ToDictionary(r => r.Code, r => r.Total);

        _max = _totals.Values.DefaultIfEmpty(1).Max();

        _loading = false;
    }
    // ── Helpers ──────────────────────────────────────────────
    int GetTotal(string code) =>
        _totals.GetValueOrDefault(code, 0);

    string GetColor(string code)
    {
        var count = GetTotal(code);

        if (count == 0) return "#d0d0d0"; // no projects — gray

        var ratio = (double)count / _max;
        // low count = light green (150), high count = dark green (40)
        var green = (int)(150 - ratio * 110); // 150 → 40
        return $"rgb(0, {green}, 0)";
    }

    string GetTypeColor(ProjectType type) => type switch
    {
        ProjectType.Brief => "#6c757d",  // gray
        ProjectType.ESMP => "#0d6efd",  // blue
        ProjectType.ESIA => "#198754",  // green
        ProjectType.Audit => "#ffc107",  // yellow
        _ => "#adb5bd"
    };
}

