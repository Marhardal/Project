@if (_loading)
{
    <p>Loading map...</p>
}
else
{
    <div class="map-wrapper" id="mapWrapper">
        <svg viewBox="0 0 1000 1000" width="600" height="600" xmlns="http://www.w3.org/2000/svg"
             stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width=".5">

            @foreach (var d in _districts)
            {
                <path id="@d.Code" d="@d.PathData" fill="@GetColor(d.Code)"
                      @onmouseover="() => _hovered = d"
                      @onmouseout="() => _hovered = null"
                      @onmousemove="async (e) => await UpdateMousePosition(e)"
                      style="cursor:pointer">
                </path>
            }

            @foreach (var d in _districts.Where(x => x.Cx > 0 && x.Cy > 0))
            {
                <svg:text x="@d.Cx.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                      y="@d.Cy.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                      text-anchor="middle"
                      dominant-baseline="middle"
                      font-size="12"
                      font-weight="600"
                      fill="@(GetTotal(d.Code) > 0 ? "#ffffff" : "#555555")"
                      stroke="none"
                      pointer-events="none"
                      style="user-select:none;">
                    @d.Code.Replace("MW", "")
                </svg:text>
            }
        </svg>

        @if (_hovered != null)
        {
            var distData = Distributions?.FirstOrDefault(d => d.Code == _hovered.Code);

            <div class="district-card" style="left:@CardLeft; top:@CardTop;">
                <div class="district-card-header">
                    <strong>@_hovered.Name</strong>
                    <span class="badge" style="background-color: @GetColor(_hovered.Code);">
                        @GetTotal(_hovered.Code) total
                    </span>
                </div>

                @if (distData?.Project != null && distData.Project.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var project in distData.Project)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    @* <span class="type-dot" style="background:@GetTypeColor(project.Type)"></span> *@
                                    @((ProjectType)project.Type)
                                </span>
                                <span class="text-dark fw-bold">@project.Total</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item text-muted">No projects</li>
                    </ul>
                }
            </div>
        }

        <div class="legend">
            <span>0</span>
            <div class="legend-gradient"></div>
            <span>@_max</span>
        </div>
    </div>
}

@code {
    bool _loading = true;
    DistrictEntry? _hovered;
    Dictionary<string, int> _totals = new();
    int _max = 1;
    List<DistrictEntry> _districts = new();
    double _mouseX;
    double _mouseY;
    double _wrapperWidth;
    double _wrapperHeight;

    const double CardWidth  = 220;
    const double CardHeight = 150;

    // ── Single record definition ─────────────────────────────
    record DistrictEntry(string Code, string Name, string PathData, double Cx = 0, double Cy = 0);
    record MousePosition(double X, double Y, double WrapperWidth, double WrapperHeight);

    [Parameter] public required DateTime? StartDate { get; set; }
    [Parameter] public required DateTime? EndDate { get; set; }
    [Parameter] public required List<DistrictDistribution>? Distributions { get; set; }

    // ── Lifecycle ────────────────────────────────────────────
    private DateTime? _prevStart;
    private DateTime? _prevEnd;

    protected override async Task OnParametersSetAsync()
    {
        if (StartDate == _prevStart && EndDate == _prevEnd) return;
        _prevStart = StartDate;
        _prevEnd   = EndDate;
        await LoadMapAsync();
    }

    // ── Load ─────────────────────────────────────────────────
    private async Task LoadMapAsync()
    {
        _loading = true;
        StateHasChanged();

        _districts.Clear();

        var svgTask       = Http.GetStringAsync(navigationManager.BaseUri + "Maps/mw.svg");
        var districtsTask = LocationService.GetLocationsAsync();
        var resultsTask   = HomeService.GetDistrictDistribution(StartDate, EndDate);

        await Task.WhenAll(svgTask, districtsTask, resultsTask);

        var dbDistricts = ((await districtsTask) ?? new())
            .Where(d => !string.IsNullOrWhiteSpace(d.Code))
            .ToDictionary(d => d.Code);

        Distributions = (await resultsTask) ?? new();

        var doc = new System.Xml.XmlDocument();
        doc.LoadXml(await svgTask);

        // Parse circle centers
        var circleCenters = new Dictionary<string, (double cx, double cy)>();
        foreach (System.Xml.XmlNode circle in doc.GetElementsByTagName("circle"))
        {
            var id = circle.Attributes?["id"]?.Value;
            var cx = circle.Attributes?["cx"]?.Value;
            var cy = circle.Attributes?["cy"]?.Value;

            if (id != null &&
                double.TryParse(cx, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out var x) &&
                double.TryParse(cy, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out var y))
            {
                circleCenters[id] = (x, y);
            }
        }

        // Parse paths
        foreach (System.Xml.XmlNode node in doc.GetElementsByTagName("path"))
        {
            var id = node.Attributes?["id"]?.Value;
            var d  = node.Attributes?["d"]?.Value;

            if (string.IsNullOrWhiteSpace(id) ||
                string.IsNullOrWhiteSpace(d)  ||
                !id.StartsWith("MW")) continue;

            var name = dbDistricts.TryGetValue(id, out var db)
                ? db.Location
                : node.Attributes?["name"]?.Value ?? id;

            var (cx, cy) = circleCenters.TryGetValue(id, out var center) ? center : (0, 0);

            _districts.Add(new DistrictEntry(id, name, d, cx, cy));
        }

        _totals = Distributions
            .Where(r => !string.IsNullOrWhiteSpace(r.Code))
            .ToDictionary(r => r.Code, r => r.Total);

        _max = _totals.Values.DefaultIfEmpty(1).Max();

        _loading = false;
    }

    // ── Mouse position ───────────────────────────────────────
    string CardLeft => (_mouseX + CardWidth + 15) > _wrapperWidth
        ? $"{_mouseX - CardWidth - 10}px"
        : $"{_mouseX + 15}px";

    string CardTop => (_mouseY + CardHeight + 15) > _wrapperHeight
        ? $"{_mouseY - CardHeight - 10}px"
        : $"{_mouseY + 15}px";

    async Task UpdateMousePosition(MouseEventArgs e)
    {
        try
        {
            var pos = await JSRuntime.InvokeAsync<MousePosition>(
                "mapHelper.getMousePosition", "mapWrapper", e.ClientX, e.ClientY);

            _mouseX        = pos.X;
            _mouseY        = pos.Y;
            _wrapperWidth  = pos.WrapperWidth;
            _wrapperHeight = pos.WrapperHeight;
        }
        catch { }
    }

    // ── Helpers ──────────────────────────────────────────────
    int GetTotal(string code) => _totals.GetValueOrDefault(code, 0);

    string GetColor(string code)
    {
        var count = GetTotal(code);
        if (count == 0) return "#d0d0d0";
        var ratio = (double)count / _max;
        var green = (int)(150 - ratio * 110);
        return $"rgb(0, {green}, 0)";
    }

    string GetTypeColor(ProjectType type) => type switch
    {
        ProjectType.Brief => "#6c757d",
        ProjectType.ESMP  => "#0d6efd",
        ProjectType.ESIA  => "#198754",
        ProjectType.Audit => "#ffc107",
        _ => "#adb5bd"
    };
}

<style>
    .map-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center; /* centers the SVG and legend */
        width: 100%;
    }

    path {
        transition: opacity 0.15s;
    }

    path:hover {
        opacity: 0.7;
    }

    .tooltip {
        position: absolute;
        top: 12px;
        right: 12px;
        background: white;
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 10px 14px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
        font-size: 0.9rem;
        pointer-events: none;
        min-width: 140px;
    }

    .legend {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 8px;
        font-size: 0.8rem;
        color: #555;
    }

    .legend-gradient {
        width: 180px;
        height: 14px;
        border-radius: 4px;
        background: linear-gradient(to right, rgb(0,150,0), rgb(0,40,0));
    }

    .district-card {
    position: absolute;
    background: white;
    border: 1px solid #ddd;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    min-width: 180px;
    max-width: 220px;
    pointer-events: none;
    z-index: 10;
    overflow: hidden;
    }

    .district-card {
        position: absolute;
        background: white;
        border: 1px solid #ddd;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        min-width: 180px;
        max-width: 220px;
        pointer-events: none;
        z-index: 10;
        overflow: hidden;
    }

    .district-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 12px;
        background: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        font-size: 0.9rem;
    }

    .district-card .list-group-item {
        font-size: 0.85rem;
        padding: 6px 12px;
    }

    .type-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-right: 6px;
    }
</style>