@typeparam TValue
@inject IJSRuntime JS
@implements IAsyncDisposable

<select id="@_selectId" multiple></select>

@code {
    [Parameter] public required List<TValue> Items { get; set; }
    [Parameter] public required Func<TValue, string> ValueSelector { get; set; }
    [Parameter] public required Func<TValue, string> LabelSelector { get; set; }
    [Parameter] public required List<string> SelectedValues { get; set; }
    [Parameter] public EventCallback<List<string>> SelectedValuesChanged { get; set; }

    private DotNetObjectReference<MultiSelect<TValue>>? _dotNetRef;
    private readonly string _selectId = $"multiselect-{Guid.NewGuid():N}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);

            var items = Items.Select(i => new
            {
                value = ValueSelector(i),
                label = LabelSelector(i)
            }).ToList();

            await JS.InvokeVoidAsync(
                "choicesHelper.initMulti",
                _selectId,
                items,
                SelectedValues,
                _dotNetRef
            );
        }
    }

    [JSInvokable]
    public async Task OnSelectionChanged(List<string> selectedValues)
        => await SelectedValuesChanged.InvokeAsync(selectedValues);

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("choicesHelper.destroy", _selectId);
        _dotNetRef?.Dispose();
    }
}