<div class="container py-2">
    <div class="row ">
        <div class="col-md-4">
            <h5 class="fw-semibold mb-2">Project Tasks</h5>
        </div>
        <div class="col-md-6">
            <div class="mb-3 input-group">
                <span class="input-group-text" id="basic-addon1">Search</span>
                <input type="search" class="form-control" placeholder="Search"
                       value="@searchQuery"
                       @oninput="OnSearchChanged" />
            </div>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#staticStatusBackdrop">
                <i class="bi bi-plus-square me-2"></i>Add
            </button>
        </div>
    </div>
    
    <div class="border rounded bg-body-tertiary">
        <TableTemplate Items="tasks" Context="task">
            <TableHeader>
                <th scope="col">#</th>
                <th scope="col">Name</th>
                <th scope="col">Assignee</th>
                <th scope="col">Priority</th>
                <th scope="col">Status</th>
                <th scope="col">DueDate</th>
                <th scope="col"></th>
                </TableHeader>
                <RowTemplate Context="task">
                    @{
                    int index = tasks.IndexOf(task) + 1;
                }
                    <td>@index</td>
                    <td>@task.Name</td>
                    <td>@task.Name</td>
                <td><PriorityItem Name="@task.Priority.ToString()" /></td>
                    <td><StatusItem Colour="@task.Status.Color" Name="@task.Status.Name"/></td>
                    <td>@task.DueDate</td>
                    <td>
                        <div class="d-flex gap-1 justify-content-end ">
                    <button data-bs-toggle="modal"
                                data-bs-target="#staticStatusBackdrop" class="rounded btn btn-sm btn-outline-success" @onclick="() => editMood(task)">
                        <i class="bi bi-pencil-square"></i>
                    </button>
                    <button class="rounded btn btn-sm btn-outline-danger">
                        <i class="bi bi-pencil-square"></i>
                    </button>
                    </div>
                    </td>
                </RowTemplate>
                </TableTemplate>
</div>


<div class="modal fade" id="staticStatusBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
                <EditForm method="post" Model="task" OnValidSubmit="edit ? UpdateTask : CreateTask" FormName="create3">
                <DataAnnotationsValidator/>
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="staticBackdropLabel">@(edit ? "Edit" : "Create") Task</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                        @if (!string.IsNullOrEmpty(Message))
                        {
                            <div class="alert alert-danger my-2" role="alert">
                                @Message
                            </div>
                            @* <div id="liveAlertPlaceholder"></div> *@
                        }
                    <div class="row">
                        <div class="col-md-6 col-sm-12">
                            <div class="mb-3">
                                <label for="Name" class="form-label">Name</label>
                                    <InputText id="Name" @bind-Value="task.Name" class="form-control" placeholder="Enter Task Name." />
                                    <ValidationMessage For="@(() => task.Name)" class="text-danger" />
                            </div>
                        </div>
                        <div class="col-md-6 col-sm-12">
                            <div class="mb-3">
                                <label for="DueDate" class="form-label">Due Date</label>
                                    @* <InputDate id="DueDate" @bind-Value="task.DueDate" class="form-control" placeholder="Enter Task Name." />
                                    <InputDate Type="InputDateType.Time" id="DueDate" @bind-Value="task.DueDate" class="form-control" placeholder="Enter Task Name." />
                                    <ValidationMessage For="@(() => task.DueDate)" class="text-danger" /> *@
                                    <div class="row">
                                        <div class="col-md-7">
                                            <InputDate id="DueDate" @bind-Value="DueDatePart" class="form-control" />
                                        </div>
                                        <div class="col-md-5">
                                            <InputDate Type="InputDateType.Time" id="DueTime" @bind-Value="DueTimePart" class="form-control" />
                                        </div>
                                    </div>
                                    <ValidationMessage For="@(() => task.DueDate)" class="text-danger" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 col-sm-12">
                            <div class="mb-3">
                                <label for="exampleFormControlInput1" class="form-label">Priority</label>
                                    <InputSelect id="Priority" @bind-Value="task.Priority" class="form-select">
                                    @foreach (var item in Enum.GetValues<Priority>())
                                    {
                                        <option value="@item">@EnumHelper.GetDisplayName(item)</option>
                                    }
                                </InputSelect>
                                    <ValidationMessage For="@(() => task.Priority)" class="text-danger" />
                            </div>
                        </div>
                        <div class="col-md-6 col-sm-12">
                            <div class="mb-3">
                                <label for="StatusID" class="form-label">Status</label>
                                    <InputSelect id="StatusID" @bind-Value="task.StatusID" class="form-select">
                                    @foreach (var item in statuses)
                                    {
                                        <option value="@item.ID">@item.Name</option>
                                    }
                                </InputSelect>
                                    <ValidationMessage For="@(() => task.Priority)" class="text-danger" />
                            </div>
                        </div>
                    </div>
                    @if (Users.Any())
                        {
                            <div class="mb-3">
                                <label for="exampleFormControlInput1" class="form-label">Assignee</label>
                                <MultiSelect TValue="LocationDTO"
                                             Items="Users"
                                             ValueSelector="l => l.ID.ToString()"
                                             LabelSelector="l => l.Location"
                                             SelectedValues="task.SelectedUserIDs.Select(id => id.ToString()).ToList()"
                                             SelectedValuesChanged="ids => task.SelectedUserIDs = ids.Where(id => !string.IsNullOrEmpty(id)).Select(Guid.Parse)
    .ToList()" />
                            </div>
                        }
                    <div class="mb-3">
                        <label for="exampleFormControlInput1" class="form-label">Description</label>
                            <InputTextArea id="Description" @bind-Value="task.Description" class="form-control" placeholder="Enter Task Description." />
                            <ValidationMessage For="@(() => task.Description)" class="text-danger" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" @onclick="edit ? UpdateTask : CreateTask" class="btn btn-primary">@(edit ? "Update" : "Create")</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>
</div>

@code {
    [SupplyParameterFromForm]
    public TasksDTO task { get; set; } = new();
    private string searchQuery = string.Empty;
    public List<TasksDTO> tasks { get; set; } = new();
    public List<StatusDTO> statuses { get; set; } = new();
    public List<LocationDTO> Users { get; set; } = new();
    private List<Guid> SelectedUserIds { get; set; } = new();

    [Parameter]
    public string ProjectID { get; set; }

    public string Message { get; set; } = string.Empty;

    bool edit = false;
    // Backing fields
    private DateOnly _dueDate = DateOnly.FromDateTime(DateTime.Now);
    private TimeOnly _dueTime = TimeOnly.MinValue;

    // Merge into the real model property whenever either changes
    private DateOnly DueDatePart
    {
        get => _dueDate;
        set
        {
            _dueDate = value;
            task.DueDate = _dueDate.ToDateTime(_dueTime);
        }
    }

    private TimeOnly DueTimePart
    {
        get => _dueTime;
        set
        {
            _dueTime = value;
            task.DueDate = _dueDate.ToDateTime(_dueTime);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        task.DueDate = DateTime.Now;
        statuses = await StatusService.GetStatusAsync(Category.Task);
        var query = await UserProfileService.GetUserProfilesAsync();
        Users = query.Select(u => new LocationDTO
        {
            ID = u.UserID,
            Location = $"{u.FirstName} {u.Surname}"
        }).ToList();
    }

    protected override async Task OnParametersSetAsync()
    {
        Guid guid;
        if (!string.IsNullOrWhiteSpace(ProjectID) && Guid.TryParse(ProjectID, out guid))
        {
            tasks = await TasksService.GetProjectTasks(guid);
        }
    }

    async Task CreateTask()
    {
        try
        {
            task.ProjectID = Guid.Parse(ProjectID);
            if (!task.SelectedUserIDs.Any())
            {
                Message = "Please make sure you have entered user.";
                return; // stop if nothing selected
            }
            task.SelectedUserIDs.ToList();
            task.createdOn = DateTime.Now;
            var result = await TasksService.CreateTaskAsync(task);
            if (result.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");

                await JSRuntime.InvokeVoidAsync("SwalService.success", "Added a Task Successfull.");

                task = new();
            }
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }

    async Task UpdateTask()
    {
        try
        {
            task.ProjectID = Guid.Parse(ProjectID);
            task.createdOn = DateTime.Now;
            var result = await TasksService.UpdateTaskAsync(task.ID, task);
            if (result.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");

                await JSRuntime.InvokeVoidAsync("SwalService.success", "Added a Task Successfull.");

                task = new();
            }
        }
        catch (Exception ex)
        {
            Message = ex.Message;
        }
    }

    async Task editMood(TasksDTO dTO)
    {
        edit = true;
        task.ID = dTO.ID;
        task.Name = dTO.Name;
        task.Priority = dTO.Priority;
        task.StatusID = dTO.StatusID;
        task.Description = dTO.Description;
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        
    }
}
