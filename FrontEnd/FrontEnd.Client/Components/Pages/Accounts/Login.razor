@page "/Account/Login"
@layout EmptyLayout
@* @rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false)) *@

<div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
    <div class="card border-0 shadow">
        <div class="card-body">

                @* { { --Step 1: Email + Password--} } *@
                <EditForm method="post" Model="loginDTO" OnValidSubmit="HandleLogin" FormName="Login">
                    <DataAnnotationsValidator />
                    <img src="/Images/MEPA.png" class="img-fluid mx-auto d-block" alt="...">

                    @if (!string.IsNullOrEmpty(Message))
                    {
                        <div class="alert alert-danger" role="alert">@Message</div>
                    }

                    <h5 class="card-title text-center">Welcome Back!</h5>

                    <div class="mb-3">
                        <label class="form-label">Email address</label>
                        <InputText type="email" class="form-control" placeholder="name@example.com"
                                   @bind-Value="loginDTO.Email" />
                        <ValidationMessage For="@(() => loginDTO.Email)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label class="form-label">Password</label>
                            <a class="nav-link" href="/ForgotPassword">Forgot Password?</a>
                        </div>
                        <InputText type="password" class="form-control" placeholder="Password"
                                   @bind-Value="loginDTO.Password" />
                        <ValidationMessage For="@(() => loginDTO.Password)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary w-100">Submit</button>
                    </div>
                </EditForm>
        </div>
    </div>
</div>

@inject NavigationManager navigationManager
@inject UserProfileService UserProfileService


@code {
    [SupplyParameterFromForm]
    private LoginDTO loginDTO { get; set; } = new();

    private string Message = string.Empty;

    async Task HandleLogin()
    {
        PreAuthResponseDTO? response = await UserProfileService.LoginAsync(loginDTO);

        if (response is not null)
        {
// Store the token in auth state so the OTP page can proceed.
// Step 1 returns valid credentials + userId, but no token yet.
            // OTP page needs the userId; it reads it from AuthState.UserId.
            AuthState.UserId = response.UserId;
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "UserId", response.UserId);
            // j
            await Task.Delay(100);
            // Navigate after auth token is stored and auth state is updated
            navigationManager.NavigateTo("/Account/verify-otp", true);
            return;
        }

        Message = "Check your credentials and try again.";
    }
}
