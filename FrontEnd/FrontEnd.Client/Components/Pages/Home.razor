<div class="my-2 row">
    <div class="col-md-12 col-sm-12 mt-sm-2">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-8">
                <div class="card-title">Projects Submitted per Month</div>
                        @* <div class="card-title">Projects Status</div> *@
                    </div>
                    <div class="col-4 text-end">
                        <NavLink class="btn btn-sm btn-outline-primary" href="Month/Project">View</NavLink>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @* <StackedChart/> *@
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-sm-12 mt-sm-2">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-8">
                        <div class="card-title">Projects Status</div>
                    </div>
                    <div class="col-4 text-end">
                        <NavLink class="btn btn-sm btn-outline-primary" href="Project/Status">View</NavLink>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (GroupedProjects.Any())
                {
                    <ApexChart TItem="GroupedProjectTypesDTO">

                        <ApexPointSeries TItem="GroupedProjectTypesDTO"
                                         Items="GroupedProjects"
                                         Name="Projects"
                                         SeriesType="SeriesType.Pie"
                                         XValue="e => e.Type.ToString()"
                                         YValue="e => e.Count" />
                    </ApexChart>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-sm-12 mt-sm-2">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-8">
                        <div class="card-title">Projects Status</div>
                    </div>
                    <div class="col-4 text-end">
                        <NavLink class="btn btn-sm btn-outline-primary" href="Project/Status">View</NavLink>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (ProjectStatuses.Any())
                {
                    <ApexChart TItem="ProjectStatusDTO">

                        <ApexPointSeries TItem="ProjectStatusDTO"
                                         Items="ProjectStatuses"
                                         Name="Projects"
                                         SeriesType="SeriesType.Pie"
                                         XValue="e => e.Status"
                                         YValue="e => e.Total" />
                    </ApexChart>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4 col-sm-12 mt-sm-2">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-8">
                <div class="card-title">Projects by Proponent</div>
                        @* <div class="card-title">Projects Status</div> *@
                    </div>
                    <div class="col-4 text-end">
                        <NavLink class="btn btn-sm btn-outline-primary" href="Proponent/Projects">View</NavLink>
                    </div>
                </div>
            </div>
            <div class="card-body">

                <TableTemplate Items="ProjectbyProponents" Context="Project">
                    <TableHeader>
                       <th scope="col">#</th>
                       <th scope="col">Proponent</th>
                       <th scope="col">Count</th>
                    </TableHeader>
                    <RowTemplate Context="Project">
                        @{
                            int index = ProjectbyProponents.IndexOf(Project) + 1;
                        }
                        <td>@index</td>
                        <td>@Project.Proponent</td>
                        <td>@Project.Count</td>
                    </RowTemplate>
                </TableTemplate>
                
                @* <canvas id="pie" width="400" height="400"></canvas> *@
            </div>
        </div>
    </div>
    <div class="col-md-8 col-sm-12 mt-sm-2">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-8">
                <div class="card-title">Recent Projects</div>
                        @* <div class="card-title">Projects Status</div> *@
                    </div>
                    <div class="col-4 text-end">
                        <NavLink class="btn btn-sm btn-outline-primary" href="/Projects">View</NavLink>
                    </div>
                </div>
            </div>
            <div class="card-body">
                
                <TableTemplate Items="RecentProjects" Context="Project">
                    <TableHeader>
                        <th scope="col">#</th>
                        <th scope="col">Project</th>
                        <th scope="col">Proponent</th>
                        <th scope="col">Status</th>
                        <th scope="col">Date</th>
                    </TableHeader>
                    <RowTemplate Context="Project">
                        @{
                            int index = RecentProjects.IndexOf(Project) + 1;
                        }
                        <td>@index</td>
                        <td>
                            <span class="d-inline-block text-truncate" style="max-width: 250px;"
                                  title="@Project.Project">@Project.Project</span>
                            </td>
                        <td>@Project.Proponent</td>
                        <td><StatusItem  Name="@Project.Status" Colour="@Project.Color"/></td>
                        <td>@Project.Date.Humanize()</td>
                    </RowTemplate>
                </TableTemplate>
            </div>
        </div>
    </div>
</div>

@if (showProfileModal)
{
    <User Profile="@userProfile" />

    <button id="openProfileModalBtn"
            type="button"
            class="d-none"
            data-bs-toggle="modal"
            data-bs-target="#staticBackdrop">
    </button>
}

@code {
    private UserProfileDTO userProfile = new();
    private bool showProfileModal;
    private bool modalShown;
    private List<ProjectbyProponentDTO>? ProjectbyProponents;
    private List<RecentProjectsDTO>? RecentProjects;
    private List<GroupedProjectTypesDTO>? GroupedProjects;
    private List<ProjectStatusDTO>? ProjectStatuses;

    protected override async Task OnInitializedAsync()
    {
        var userId = Guid.Parse("94f18329-f144-41bd-8f25-22b887f686e7");

        var profile = await UserProfileService.GetUserProfileAsync(userId);

        ProjectbyProponents = await HomeService.GetProjectbyProponent();

        RecentProjects = await HomeService.GetRecentProjects();

        GroupedProjects = await HomeService.GetGroupedProjects()
                      ?? new List<GroupedProjectTypesDTO>();

        ProjectStatuses = await HomeService.GetProjectStatuses()
                      ?? new List<ProjectStatusDTO>();


        if (profile == null || profile.ID == Guid.Empty)
        {
            userProfile = new UserProfileDTO();
            showProfileModal = true;
        }
        else
        {
            userProfile = profile;
            showProfileModal = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showProfileModal && !modalShown)
        {
            modalShown = true;

            await JSRuntime.InvokeVoidAsync(
                "eval",
                "document.getElementById('openProfileModalBtn')?.click();"
            );
        }
    }
}