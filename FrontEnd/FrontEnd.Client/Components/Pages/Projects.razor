@page "/Projects"
@* @rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false)) *@


<PageTitle>Projects</PageTitle>
@* 994190633 *@
<div class="row">
    <div class="col-md-8">
        <h3>Projects</h3>
    </div>
    <div class="col-md-2 col-sm-2 text-md-end">
        <div class="input-group rounded-pill justify-content-md-end">
            <span class="input-group-text" id="basic-addon1">Show</span>
            <select class="form-control-sm" @bind="pageSize" @bind:after="OnPageSizeChanged">
                <option value="10">10</option>
                <option value="15">15</option>
                <option value="20">20</option>
                <option value="30">30</option>
                <option value="40">40</option>
                <option value="50">50</option>
            </select>
        </div>
    </div>
    <div class="col-md-2 col-sm-2 text-md-end">

        <div class="dropdown">
            <button class="btn btn-secondary border text-white dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                Export
            </button>
            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end dropdown-menu-start">
                <li>
                    <button type="button" class="btn btn-sm dropdown-item" @onclick="() => createPDF()">
                        <i class="fa-solid fa-file-pdf"></i>PDF
                    </button>
                </li>
                <li>
                    <button type="button" class="btn btn-sm dropdown-item" @onclick="() => createExcel()">
                        <i class="fa-solid fa-file-excel"></i>Excel
                    </button>
                </li>
            </ul>
        </div>
    </div>
    @* <div class="col-md-2 col-sm-2 text-md-end">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#staticBackdrop"><i
            class="bi bi-plus-square me-2"></i>Add</button>
    </div> *@
</div>
@if (projects != null)
{
    <div class="row">
        <div class="col-md-7">
            <div class="mb-3 input-group">
                <span class="input-group-text" id="basic-addon1">Search</span>
                <input type="search" class="form-control" placeholder="Search"
                       value="@searchQuery" @oninput="OnSearchChanged" />
            </div>
        </div>
        <div class="col-md-2">
            <div class="mb-3 input-group">
                <label class="input-group-text" for="inputGroupSelect01">Type</label>
                <select class="form-select" @bind="selectedType" @bind:after="OnFilterChanged">
                    <option value="">All</option>
                    @foreach (var type in Enum.GetValues<ProjectType>().Where(t => t != ProjectType.Brief))
                    {
                        <option value="@type">@EnumHelper.GetDisplayName(type)</option>
                    }
                </select>
            </div>
        </div>
        <div class="col-md-3">
            <div class="mb-3 input-group">
                <label class="input-group-text" for="inputGroupSelect01">Status</label>
                <select class="form-select" @bind="selectedStatus" @bind:after="OnFilterChanged">
                    <option value="">All Statuses</option>
                    @foreach (var status in statuses)
                    {
                        <option value="@status.ID">@status.Name</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="border rounded bg-body-tertiary">
        <TableTemplate Items="pagedProjects" Context="project">
            <TableHeader>
                <th scope="col">#</th>
                <th scope="col">Name</th>
                <th scope="col">Proponent</th>
                <th scope="col">Location</th>
                <th scope="col">Type</th>
                <th scope="col">Status</th>
                <th scope="col">Submission</th>
                <th scope="col"></th>
            </TableHeader>

            <RowTemplate Context="project">
                @{
                    int index = (currentPage - 1) * pageSize + pagedProjects.IndexOf(project) + 1;
                }
                <td>@index</td>
                @* <td>@project.Name</td> *@
                <td>
                    <span class="d-inline-block text-truncate" style="max-width: 350px;"
                    title="@project.Name">@project.Name</span>
                </td>
                <td>@project?.Proponent?.Name</td>
                <td>@(project?.ProjectLocations?.Any() == true
                        ? string.Join(", ", project?.ProjectLocations?.Select(l => l.Location?.Location).Where(l => l != null))
                        : "—")</td>

                <td>@project?.ProjectType.ToString()</td>
                @{
                    var status = project?.Trackings.OrderByDescending(p => p.createdOn).FirstOrDefault()?.Status;
                }

                <td class="py-2">
                    <StatusItem Name="@status?.Name" Colour="@status?.Color"></StatusItem>
                </td>
                <td>@project?.SubmissionDate.ToString("yyyy-MMM, dd")</td>
                <td class="py-2">
                    <div class="d-flex gap-1 justify-content-end ">
                        <NavLink class="rounded btn btn-sm btn-outline-warning" href="@($"Project/View/{project.Id}")">
                            <i class="bi bi-eye-fill"></i>
                        </NavLink>
                        @* @onclick="() => editProposal(proposal)" *@
                        <button data-bs-toggle="modal"
                                data-bs-target="#staticBackdrop" class="rounded btn btn-sm btn-outline-success" @onclick="() => editProject(project)">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                        <NavLink class="rounded btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </NavLink>
                    </div>
                </td>
            </RowTemplate>
        </TableTemplate>
        <div class="justify-content-center d-flex">
            <Paginator pageSize="pageSize" currentPage="currentPage" totalItems="filteredProjects.Count" OnPageChanged="Pages => currentPage = Pages" />
        </div>
    </div>
}
else
{
    <p>Please enter some projects via Project Briefs.</p>
}


<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <EditForm method="post" Model="Proposal" OnValidSubmit="HandleUpdate"
                      FormName="create">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="staticBackdropLabel">Edit Project</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <DataAnnotationsValidator />
                    @if (!string.IsNullOrEmpty(submitMessage))
                    {
                        <div class="alert alert-danger my-2" role="alert">
                            @submitMessage
                        </div>
                    }
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="Name" class="form-label">Project Name</label>
                                <InputText @bind-Value="Proposal.Name" class="form-control" id="Name"
                                           placeholder="Enter Project Name."></InputText>
                                <ValidationMessage For="@(() => Proposal.Name)" class="text-danger" />
                            </div>
                        </div>
                        <div class="col-md-6">

                            <div class="mb-3">
                                <label for="ProponentID" class="form-label">Project Proponent</label>
                                <InputSelect @bind-Value="Proposal.ProponentID" id="ProponentID" class="form-select"
                                             aria-label="Default select example">
                                    <option value="">-- Select Proponent --</option>
                                    @foreach (var proponent in proponents)
                                    {
                                        <option value="@proponent.ID">@proponent.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => Proposal.ProponentID)" class="text-danger" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="Location" class="form-label">Location</label>
                                @* <InputText @bind-Value="Proposal.Location" class="form-control" id="Location"
                                           placeholder="Enter Project Location.">
                                </InputText>
                                <ValidationMessage For="@(() => Proposal.Location)" class="text-danger" /> *@
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="SubmissionDate" class="form-label">Submission Date</label>
                                <InputDate @bind-Value="Proposal.SubmissionDate" class="form-control"
                                           id="SubmissionDate"></InputDate>
                                <ValidationMessage For="@(() => Proposal.SubmissionDate)" class="text-danger" />
                            </div>
                        </div>
                    </div>
                    @* @{
                        var selectedStatus = statuses.FirstOrDefault(s => s.ID == Proposal?.Tracking?.StatusID);
                        var isApproved = selectedStatus?.Name == "Approved";
                    }
                    @if (isEditMode && Proposal?.Tracking != null)
                    { *@
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="Status" class="form-label">Status</label>

                                    <InputSelect @bind-Value="Proposal.Tracking.StatusID"
                                                 id="Status"
                                                 class="form-select">
                                        <option value="">-- Select Status --</option>
                                        @foreach (var status in statuses)
                                        {
                                            <option value="@status.ID">@status.Name</option>
                                        }
                                    </InputSelect>

                                    <ValidationMessage For="@(() => Proposal.Tracking.StatusID)" class="text-danger" />
                                </div>
                            </div>

                            
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="ProjectType" class="form-label">Type</label>

                                        <InputSelect @bind-Value="Proposal.ProjectType"
                                                     id="ProjectType"
                                                     class="form-select">
                                            <option value="">-- Select Project Type --</option>
                                            @foreach (var type in Enum.GetValues<ProjectType>().Where(t => t != ProjectType.Brief))
                                            {
                                                <option value="@type">@EnumHelper.GetDisplayName(type)</option>
                                            }
                                        </InputSelect>

                                        <ValidationMessage For="@(() => Proposal.ProjectType)" class="text-danger" />
                                    </div>
                                </div>
                        </div>
                    @* } *@
                    <div class="mb-3">
                        <label for="Description" class="form-label">Description</label>
                        <InputTextArea @bind-Value="Proposal.Description" class="form-control" id="Description" rows="3"
                                       placeholder="Enter Project Description."></InputTextArea>
                        <ValidationMessage For="@(() => Proposal.Description)" class="text-danger" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span>Updating</span>
                            <span class="submitting-dots">
                                <span>.</span>
                                <span>.</span>
                                <span>.</span>
                            </span>
                        }
                        else
                        {
                            <span>Update</span>
                        }
                    </button>
                </div>

            </EditForm>
        </div>
    </div>
</div>

@code {

    [SupplyParameterFromForm]
    private ProjectDTO Proposal { get; set; } = new();
    List<ProjectDTO> projects = new();
    private List<StatusDTO> statuses = new();
    private List<ProjectType> projectTypes;
    private List<ProponentsDTO> proponents = new();

    private List<ProjectDTO> proposals = new();
    private string submitMessage = string.Empty;
    private int pageSize = 10;
    private int currentPage = 1;
    private string searchQuery = string.Empty;
    private ProjectType? selectedType = null;
    private Guid? selectedStatus = null;
    private int totalPages => (int)Math.Ceiling(filteredProjects .Count / (double)pageSize);
    bool isLoading = false;

    private List<ProjectDTO> filteredProjects => projects?
        .Where(p =>
            (string.IsNullOrWhiteSpace(searchQuery) ||
            p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
            &&
            (selectedType == null || p.ProjectType == selectedType)
            &&
            (selectedStatus == null || p.Trackings
                .OrderByDescending(t => t.createdOn)
                .FirstOrDefault()?.StatusID == selectedStatus))
        .ToList() ?? new();


    private List<ProjectDTO> pagedProjects =>
        filteredProjects
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();

    private void OnPageSizeChanged()
    {
        currentPage = 1;
        StateHasChanged();
    }

    private void OnFilterChanged()
    {
        currentPage = 1;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await JSRuntime.InvokeVoidAsync("Spinner.show");
        try
        {
            // Fetch projects and proponents with null-checks to prevent null assignments
            var projectResult = await ProjectService.GetProjectAsync(false);
            projects = projectResult ?? new List<ProjectDTO>();
            // projects = await ProjectService.GetProjectAsync(false) ?? new List<ProjectDTO>();

            var proponentResult = await ProponentService.GetProponentsAsync();
            proponents = proponentResult ?? new List<ProponentsDTO>();

            var statusResult = await StatusService.GetStatusAsync();
            statuses = (statusResult ?? new List<StatusDTO>()).Where(s => s.SortOrder >= 3).ToList();
        }
        catch (Exception ex)
        {

            // throw;
        }
        finally
        {
            await Task.Delay(200);
            await JSRuntime.InvokeVoidAsync("Spinner.hide");
        }
    }

    async Task editProject(ProjectDTO project)
    {
        submitMessage = null;
        var tracking = project.Trackings?
            .OrderByDescending(t => t.createdOn)
            .FirstOrDefault();
        var selectedStatus = statuses.FirstOrDefault(s => s.ID == Proposal?.Tracking?.StatusID);

        if (selectedStatus?.Name == "Approved" && project.ProjectType == ProjectType.Brief)
        {
            submitMessage = "Approved Project Brief must be assigned a valid project type.";
            return;
        }

        var defaultStatusId = statuses.FirstOrDefault()?.ID ?? Guid.Empty;

        Proposal = new ProjectDTO()
        {
            Id = project.Id,
            Name = project.Name,
            // Location = project.Location,
            ProponentID = project.ProponentID,
            ProjectType = project.ProjectType,
            Description = project.Description,
            SubmissionDate = project.SubmissionDate,
            createdOn = project.createdOn,
            Tracking = new TrackingDTO()
            {
                StatusID = tracking?.StatusID ?? defaultStatusId
            }
        };

        var statusResult = await StatusService.GetStatusAsync();
        statuses = (statusResult ?? new List<StatusDTO>()).Where(s => s.SortOrder >= 3).ToList();

        await JSRuntime.InvokeVoidAsync("showModal", "staticBackdrop");
    }
    
    async Task HandleUpdate()
    {
        isLoading = true;
        submitMessage = null;
        try
        {
            var selectedStatus = statuses.FirstOrDefault(s => s.ID == Proposal?.Tracking?.StatusID);

            if (selectedStatus?.Name == "Approved" && Proposal.ProjectType == ProjectType.Brief)
            {
                submitMessage = "Approved Project Brief must be assigned a valid project type.";
                return;
            }
            // EditPerson.ProponentID = ;
            // Proponent!.ProponentID = Guid.Parse(PropID);
            Proposal.updatedOn = DateTime.Now;
            var response = await ProjectService.UpdateProjectAsync(Proposal.Id, Proposal);
            if (response.IsSuccessStatusCode)
            {
                // Refresh list

                // Reset form
                Proposal = new();

                // await JSRuntime.InvokeVoidAsync("closeModal", "staticBackdrop");
                // Close modal
                // await JSRuntime.InvokeVoidAsync("bootstrap.Modal.getInstance", modalElement).AsTask();
                // isEditMode = false;
                // submitMessage = "Proposal updated successfully!";
                // await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");
                await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");

                await JSRuntime.InvokeVoidAsync("SwalService.success", "Project updated successfully!");

            }
            else
            {
                submitMessage = $"Error {response.StatusCode}: {await response.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            submitMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            projects = await ProjectService.GetProjectAsync(false);
            StateHasChanged();
        }
        // submitMessage = null;
    }
    
    private Timer? _debounce;

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? string.Empty;
        currentPage = 1; // reset to first page on new search
        _debounce?.Dispose();
        _debounce = new Timer(_ => InvokeAsync(StateHasChanged), null, 400, Timeout.Infinite);
    }

    async Task createExcel()
    {
        var bytes = await ProjectService.ExportProjectAsync(selectedType, searchQuery, selectedStatus.ToString());
        await JSRuntime.InvokeVoidAsync("downloadFile",
            $"Projects_{DateTime.Now:yyyyMMdd}.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            bytes);
    }

    async Task createPDF()
    {
        var bytes = await ProjectService.ExportProjectPDFAsync(selectedType, searchQuery, selectedStatus.ToString());
        await JSRuntime.InvokeVoidAsync("downloadFile",
            $"Projects_{DateTime.Now:yyyyMMdd}.pdf",
            "application/pdf",
            bytes);
    }
}
