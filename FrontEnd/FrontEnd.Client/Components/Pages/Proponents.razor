@page "/proponents"
@inherits PermissionGuardedPage

<PageTitle>Proponents</PageTitle>

<div class="mb-2 row g-0 align-items-center ">
    <div class="col-md-4">
        <div class="d-flex flex-wrap gap-2">
            <div class="flex-grow-1 flex-md-grow-0">
                <h3>Proponents</h3>
            </div>
            <div class="flex-grow-1 flex-md-grow-0">
                <div class="input-group rounded-pill small">
                    <span class="input-group-text" id="basic-addon1">Show</span>
                    <select class="form-control-sm" @bind="pageSize" @bind:after="OnPageSizeChanged">
                        <option value="10">10</option>
                        <option value="15">15</option>
                        <option value="20">20</option>
                        <option value="30">30</option>
                        <option value="40">40</option>
                        <option value="50">50</option>
                    </select>
                </div>
            </div>
        </div>

    </div>
    <div class="col-md-5">
        <div class="input-group">
            <span class="input-group-text" id="basic-addon1">Search</span>
            <input type="search" class="form-control" placeholder="Search"
                   value="@searchQuery"
                   @oninput="OnSearchChanged" />
        </div>
    </div>

    <div class="col-md-3 col-12">
        @if (Permissions.Can(PageSlug, "Export"))
        {
            <div class="d-flex flex-wrap gap-2 justify-content-end">
                <div class="dropdown">
                    <button class="btn btn-secondary border text-white dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Export
                    </button>
                    <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end dropdown-menu-start">
                        <li>
                            <button type="button" class="btn btn-sm dropdown-item" @onclick="() => createPDF()">
                                <i class="fa-solid fa-file-pdf"></i>PDF
                            </button>
                        </li>
                        <li>
                            <button type="button" class="btn btn-sm dropdown-item" @onclick="() => createExcel()">
                                <i class="fa-solid fa-file-excel"></i>Excel
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="flex-grow-1 flex-md-grow-0">
                    <!-- Grows to fill space on mobile -->
                    <button type="button" @onclick="OpenCreateModal" class="btn btn-primary w-100 w-md-auto"
                    data-bs-toggle="modal" data-bs-target="#staticBackdrop">
                        <i class="fa-solid fa-plus me-2"></i>Add
                    </button>
                </div>
            </div>
        }
    </div>
</div>
@if (proponents?.Count > 0)
{
    <div class="border rounded bg-body-tertiary">
        <div class="p-2">

            <TableTemplate Items="pagedProponents" Context="proponent">

                <TableHeader>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Postal Address</th>
                    <th scope="col">Location</th>
                    <th scope="col">Created On</th>
                    <th scope="col"></th>
                </TableHeader>
                <RowTemplate Context="proponent">
                    @{
                        int index = proponents.IndexOf(proponent) + 1;
                    }
                    <td>@index</td>
                    <td>@proponent.Name</td>
                    <td>@proponent.Address</td>
                    <td>@proponent.Location</td>
                    <td>@proponent.createdOn.ToString("MMM dd, yyyy")</td>
                    <td>
                        <div class="d-flex gap-1 justify-content-center">
                            @if (Permissions.Can(PageSlug, "Details"))
                            {
                                <NavLink class="btn btn-sm btn-outline-primary" href="@($"/Proponent/View/{proponent.ID}")">
                                    <i class="bi bi-eye"></i>
                                </NavLink>
                            }
                            @if (Permissions.Can(PageSlug, "Edit"))
                            {
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => EditProponent(proponent)"
                                title="Edit" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            }
                            @if (Permissions.Can(PageSlug, "Delete"))
                            {
                                <button class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </div>
                    </td>
                </RowTemplate>

            </TableTemplate>
        </div>

        <div class="justify-content-center d-flex">
            <Paginator pageSize="pageSize" currentPage="currentPage" totalItems="filteredProponents.Count" OnPageChanged="Pages => currentPage = Pages" />
        </div>
    </div>
}
else
{
    <p class="text-center my-5 py-5">No proponents found. Adjust your search criteria or Create a new Proponent.</p>
}


<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <EditForm method="post" Model="Proponent" OnValidSubmit="@(isEditMode ? HandleUpdate : HandleSubmission)" FormName="create">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="staticBackdropLabel">@* Create Proponent *@ @(isEditMode ? "Edit Proponent" : "Create Proponent")</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <DataAnnotationsValidator />
                    @* <ValidationSummary /> *@
                    <div class="mb-3">
                        <label for="Name" class="form-label">Proponent Name</label>
                        <InputText id="Name" @bind-Value="Proponent.Name" class="form-control"
                                   placeholder="Enter Proponent Name."></InputText>
                        <ValidationMessage For="@(() => Proponent.Name)" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="Address" class="form-label">Postal Address</label>
                        <InputText id="Address" @bind-Value="Proponent.Address" class="form-control"
                                   placeholder="Enter Proponent Address."></InputText>
                        <ValidationMessage For="@(() => Proponent.Address)" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="exampleFormControlInput1" class="form-label">Proponent Location</label>
                        <InputText id="Location" @bind-Value="Proponent.Location" class="form-control"
                                   placeholder="Enter Proponent Location." />
                        <ValidationMessage For="@(() => Proponent.Location)" class="text-danger" />
                    </div>

                    @if (!string.IsNullOrEmpty(submitMessage))
                    {
                        <div class="alert @(submitMessage?.Contains("Error") == true ? "alert-danger" : "alert-success") alert-dismissible fade show"
                             role="alert">
                            @submitMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">
                        @(isEditMode ? "Update" : "Create")
                    </button>

                </div>
            </EditForm>

        </div>
    </div>
</div>

@code {
    private List<ProponentsDTO>? proponents;

    [SupplyParameterFromForm]
    private ProponentsDTO? Proponent { get; set; } = new();

    private ElementReference modalElement;

    bool isSubmitting = false;
    string? submitMessage;
    private bool loaded = false;
    private bool isEditMode = false;
    private string searchQuery = string.Empty;
    private int pageSize = 10;
    private int currentPage = 1;
    // private int totalPages => (int)Math.Ceiling(filteredProponents.Count / (double)pageSize);

    private List<ProponentsDTO> filteredProponents =>
        proponents?
            .Where(p =>
                string.IsNullOrWhiteSpace(searchQuery) ||
                p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                p.Address.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                p.Location.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
            .ToList() ?? new();

    private List<ProponentsDTO> pagedProponents =>
        filteredProponents
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();

    void OpenCreateModal()
    {
        isEditMode = false;
        Proponent = new ProponentsDTO(); // reset form
    }

    void EditProponent(ProponentsDTO prop)
    {
        isEditMode = true;
        Proponent = prop;
    }

    protected override string PageSlug
    {
        get
        {
            var relativePath = navigationManager.ToBaseRelativePath(navigationManager.Uri);
            var firstSegment = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
            return (firstSegment ?? string.Empty).ToLowerInvariant();
        }
    }

    protected override async Task OnPageInitializedAsync()
    {
        await JSRuntime.InvokeVoidAsync("Spinner.show");
        try
        {
            proponents = await ProponentService.GetProponentsAsync();
        }
        catch (Exception ex)
        {

        }
        finally
        {
            await Task.Delay(200);
            await JSRuntime.InvokeVoidAsync("Spinner.hide");
        }
    }

    async Task HandleSubmission()
    {
        isSubmitting = true;
        submitMessage = null;
        try
        {
            Proponent.createdOn = DateTime.Now;
            var response = await ProponentService.CreateProponentAsync(Proponent);
            if (response.IsSuccessStatusCode)
            {
                // Refresh list
                proponents = await ProponentService.GetProponentsAsync();
                // Reset form
                Proponent = new();
                // Close modal
                // await JSRuntime.InvokeVoidAsync("bootstrap.Modal.getInstance", modalElement).AsTask();
                await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");
                
                await JSRuntime.InvokeVoidAsync("SwalService.success", "Proponent created successfully!");

            }
            else
            {
                submitMessage = $"Error {response.StatusCode}: {await response.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            submitMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }
    
    protected async Task HandleUpdate()
    {
        isSubmitting = true;
        submitMessage = null;
        try
        {
            // EditPerson.ProponentID = ;
            // Proponent!.ProponentID = Guid.Parse(PropID);
            Proponent.updatedOn = DateTime.Now;
            var response = await ProponentService.UpdateProponentAsync(Proponent.ID, Proponent);
            if (response.IsSuccessStatusCode)
            {
                // Refresh list
                proponents = await ProponentService.GetProponentsAsync();
                
                // Reset form
                Proponent = new();
                
                // await JSRuntime.InvokeVoidAsync("closeModal", "staticBackdrop");
                // Close modal
                // await JSRuntime.InvokeVoidAsync("bootstrap.Modal.getInstance", modalElement).AsTask();
                isEditMode = false;
                await JSRuntime.InvokeVoidAsync("SwalService.success", "Proponent updated successfully!");
                await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");
                

            }
            else
            {
                submitMessage = $"Error {response.StatusCode}: {await response.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            submitMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private Timer? _debounce;

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? string.Empty;
        currentPage = 1; // reset to first page on new search
        _debounce?.Dispose();
        _debounce = new Timer(_ => InvokeAsync(StateHasChanged), null, 400, Timeout.Infinite);
    }

    private void OnPageSizeChanged()
    {
        currentPage = 1;
        StateHasChanged();
    }

    async Task createExcel()
    {
        var bytes = await ProponentService.ExportProponentsExcelAsync(searchQuery);
        await JSRuntime.InvokeVoidAsync("downloadFile",
            $"Proponents_{DateTime.Now:yyyyMMdd}.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            bytes);
    }

    async Task createPDF()
    {
        var bytes = await ProponentService.ExportProponentsPDFAsync(searchQuery);
        await JSRuntime.InvokeVoidAsync("downloadFile",
            $"Proponents_{DateTime.Now:yyyyMMdd}.pdf",
            "application/pdf",
            bytes);
    }



}

