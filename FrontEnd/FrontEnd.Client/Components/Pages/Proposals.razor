@page "/Proposals"
@inherits PermissionGuardedPage

<PageTitle>Project Briefs</PageTitle>

@if (proposals != null && proposals.Count > 0)
{
    <div class="row">
        <div class="@GetSearchColClass()">
            <h3>Project Briefs</h3>
        </div>
        
        <div class="col-md-2">
            <div class="mb-3 input-group rounded-pill justify-content-end">
                <span class="input-group-text" id="basic-addon1">Show</span>
                <select class="form-control-sm" @bind="pageSize" @bind:after="OnPageSizeChanged">
                    <option value="10">10</option>
                    <option value="15">15</option>
                    <option value="20">20</option>
                    <option value="30">30</option>
                    <option value="40">40</option>
                    <option value="50">50</option>
                </select>
            </div>
        </div>
        @if (CanExport)
        {
            <div class="col-md-2 text-end">
                    <div class="dropdown">
                        <button class="btn btn-secondary border text-white dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Export
                        </button>
                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end dropdown-menu-start">
                            <li>
                                <button type="button" class="btn btn-sm dropdown-item" @onclick="() => createPDF()">
                                    <i class="fa-solid fa-file-pdf"></i>PDF
                                </button>
                            </li>
                            <li>
                                <button type="button" class="btn btn-sm dropdown-item" @onclick="() => createExcel()">
                                    <i class="fa-solid fa-file-excel"></i>Excel
                                </button>
                            </li>
                        </ul>
                    </div>
            </div>
        }
        @if (CanCreate)
        {
            <div class="col-md-2 text-end">
               
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
                        <i class="fa-solid fa-plus me-2"></i>Add
                    </button>
            </div>
        }
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="mb-3 input-group">
                <span class="input-group-text" id="basic-addon1">Search</span>
                <input type="search" class="form-control" placeholder="Search"
                       value="@searchQuery"
                       @oninput="OnSearchChanged" />
            </div>
        </div>
    </div>

    <div class="border rounded bg-body-tertiary">
        <TableTemplate Items="pagedProposals" Context="proposal">
            <TableHeader>
                <th scope="col">#</th>
                <th scope="col">Name</th>
                <th scope="col">Proponent</th>
                <th scope="col">Location</th>
                <th scope="col">Status</th>
                <th scope="col">Created On</th>
                @if (HasTableActions)
            {
                <th scope="col"></th>
                }
            </TableHeader>
            <RowTemplate Context="proposal">
                @{
                    int index = (currentPage - 1) * pageSize + pagedProposals.IndexOf(proposal) + 1;
                }
                <td>@index</td>
                <td>
                    <span class="d-inline-block text-truncate" style="max-width: 350px;"
                          title="@proposal.Name">@proposal.Name</span>
                </td>
                <td class="py-2">@proposal.Proponent?.Name</td>
                <td class="py-2">
                    @(proposal.ProjectLocations?.Any() == true
                        ? string.Join(", ", proposal.ProjectLocations.Select(l => l.Location?.Location).Where(l => l != null))
                        : "—")
                </td>
                @{
                    var status = proposal?.Trackings.OrderByDescending(p => p.createdOn).FirstOrDefault()?.Status;
                }

                <td class="py-2">
                    <StatusItem Name="@status?.Name" Colour="@status?.Color"></StatusItem>
                </td>
                <td class="py-2">@proposal.createdOn.ToString("yyyy-MMM, dd")</td>
                    @if (HasTableActions)
                {
                    <td class="py-2">
                        <div class="d-flex gap-1 justify-content-end ">
                            @if (CanDetails)
                            {
                                <NavLink class="rounded btn btn-sm btn-outline-warning" href="@($"Project/View/{proposal.Id}")">
                                    <i class="bi bi-eye-fill"></i>
                                </NavLink>
                            }
                            @if (CanEdit)
                            {
                                <button data-bs-toggle="modal"
                                        data-bs-target="#staticBackdrop" @onclick="() => editProposal(proposal)" class="rounded btn btn-sm btn-outline-success">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            }
                            @if (CanDelete)
                            {
                                <NavLink class="rounded btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </NavLink>
                            }
                        </div>
                    </td>
            }
            </RowTemplate>
        </TableTemplate>

        <div class="justify-content-center d-flex">
            <Paginator pageSize="pageSize" currentPage="currentPage" totalItems="filteredProposals.Count" OnPageChanged="Pages => currentPage = Pages" />
        </div>
    </div>    
}
else
{
<div class="d-flex flex-column align-items-center justify-content-center min-vh-100">
        <h5 class="mb-3">No Project Briefs Found</h5>
        <p class="mb-4 text-muted">Please enter a new Project Brief.</p>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
            <i class="bi bi-plus-square me-2"></i>Add
        </button>
    </div>
}


<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
         aria-labelledby="staticBackdropLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <EditForm method="post" Model="Proposal" OnValidSubmit="@(isEditMode? HandleUpdate : HandleSubmission)"
                          FormName="create">
                    <div class="modal-header">
                    <h1 class="modal-title fs-5" id="staticBackdropLabel">@(isEditMode ? "Edit Project Brief" : "Create Project Brief") </h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <DataAnnotationsValidator />
                        <ValidationSummary/>
                    @if (!string.IsNullOrEmpty(submitMessage))
                    {
                        <div class="alert alert-danger my-2" role="alert">
                            @submitMessage
                        </div>
                        @* <div id="liveAlertPlaceholder"></div> *@
                    }
                    <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="Name" class="form-label">Project Name</label>
                                    <InputText @bind-Value="Proposal.Name" class="form-control" id="Name"
                                               placeholder="Enter Project Name."></InputText>
                                    <ValidationMessage For="@(() => Proposal.Name)" class="text-danger" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="Location" class="form-label">Category</label>
                                    @* <InputText @bind-Value="Proposal.Location" class="form-control" id="Location"
                                               placeholder="Enter Project Location.">
                                    </InputText> *@
                                    <InputSelect @bind-Value="Proposal.CategoryID"
                                                 id="CategoryID"
                                                 class="form-select">
                                        <option value="">-- Select Project Category --</option>
                                        @foreach (var category in categories)
                                        {
                                            <option value="@category.ID">@category.Name</option>
                                        }
                                    </InputSelect>

                                    <ValidationMessage For="@(() => Proposal.CategoryID)" class="text-danger" />
                                    @if (!Proposal.SelectedLocationIds.Any() && isSubmitting)
                                    {
                                        <div class="text-danger small mt-1">Please select at least one location.</div>
                                    }
                                </div>
                            </div>
                        </div>
                    
                    <div class="row">

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label for="ProponentID" class="form-label">Project Proponent</label>
                            @* <InputSelect @bind-Value="Proposal.ProponentID" id="ProponentID" class="form-select"
                                                 aria-label="Default select example">
                                        <option value="">-- Select Proponent --</option>
                                        @foreach (var proponent in proponents)
                                        {
                                            <option value="@proponent.ID">@proponent.Name</option>
                                        }
                                    </InputSelect> *@
                            @* With Guid *@
                            <SelectSearch Items="proponents.Select(p => new SelectSearch.ChoiceItem(p.ID.ToString(), p.Name)).ToList()"
                                          SelectedValue="@Proposal.ProponentID.ToString()"
                                          SelectedValueChanged="@(val => Proposal.ProponentID = Guid.Parse(val!))"
                                          Placeholder="Select Proponent"
                                          SearchPlaceholder="Search proponents..." />
                            <ValidationMessage For="@(() => Proposal.ProponentID)" class="text-danger" />
                        </div>

                        </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="SubmissionDate" class="form-label">Submission Date</label>
                                    <InputDate @bind-Value="Proposal.SubmissionDate" class="form-control"
                                               id="SubmissionDate"></InputDate>
                                    <ValidationMessage For="@(() => Proposal.SubmissionDate)" class="text-danger" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="Location" class="form-label">Location</label>
                                @* <InputText @bind-Value="Proposal.Location" class="form-control" id="Location"
                                               placeholder="Enter Project Location.">
                                    </InputText> *@
                                @* <InputSelect @bind-Value="Proposal.LocationID"
                                             id="LocationID"
                                             class="form-select">
                                    <option value="">-- Select Project Location --</option>
                                    @foreach (var location in locations)
                                    {
                                        <option value="@location.ID">@location.Location</option>
                                    }
                                </InputSelect> *@
                                @if (locations.Any())
                                {

                                    <MultiSelect Locations="locations"
                                                 SelectedLocationIds="Proposal.SelectedLocationIds"
                                                 SelectedLocationIdsChanged="@(ids => Proposal.SelectedLocationIds = ids)"></MultiSelect>
                                }
                                @* <ValidationMessage For="@(() => Proposal.LocationID)" class="text-danger" /> *@
                                @if (!Proposal.SelectedLocationIds.Any() && isSubmitting)
                                {
                                    <div class="text-danger small mt-1">Please select at least one location.</div>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="Status" class="form-label">Status</label>

                                @* To this *@
                                @if (Proposal.Tracking != null)
                                {
                                <InputSelect @bind-Value="Proposal.Tracking.StatusID"
                                             id="Status"
                                             class="form-select">
                                    <option value="">-- Select Status --</option>
                                    @foreach (var status in statuses)
                                    {
                                        <option value="@status.ID">@status.Name</option>
                                    }
                                </InputSelect>
                                }
                                @if (Proposal?.Tracking != null)
                                {
                                    <ValidationMessage For="@(() => Proposal.Tracking.StatusID)" class="text-danger" />
                                }
                            </div>
                        </div>
                        </div>
                    @{
                        var selectedStatus = statuses.FirstOrDefault(s => s.ID == Proposal?.Tracking?.StatusID);
                        var isApproved = selectedStatus?.Name == "Collected";
                        var countstatus = statuses.Count();
                        var lastStatus = statuses.Last().SortOrder == selectedStatus.SortOrder;
                    }
                    @if (isEditMode && Proposal?.Tracking != null && lastStatus && contacts.Any())
{
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label for="Status" class="form-label">Collected By</label>

                <InputSelect @bind-Value="Proposal.Tracking.StatusID"
                             id="Status"
                             class="form-select">
                    <option value="">-- Select Status --</option>
                    @foreach (var status in contacts)
                    {
                        <option value="@status.Id">@status.FullName</option>
                    }
                </InputSelect>

                <ValidationMessage For="@(() => Proposal.Tracking.StatusID)" class="text-danger" />
            </div>
        </div>

        @if (isApproved)
        {
            <div class="col-md-6">
                <div class="mb-3">
                    <label for="ProjectType" class="form-label">Type</label>

                    <InputSelect @bind-Value="Proposal.ProjectType"
                                 id="ProjectType"
                                 class="form-select">
                        <option value="">-- Select Project Type --</option>
                        @foreach (var type in Enum.GetValues<ProjectType>().Where(t => t != ProjectType.Brief))
                        {
                            <option value="@type">@EnumHelper.GetDisplayName(type)</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="@(() => Proposal.ProjectType)" class="text-danger" />
                </div>
            </div>
        }
    </div>
                    }
                    <div class="mb-3">
                            <label for="Description" class="form-label">Description</label>
                            <InputTextArea @bind-Value="Proposal.Description" class="form-control" id="Description" rows="3"
                                           placeholder="Enter Project Description."></InputTextArea>
                            <ValidationMessage For="@(() => Proposal.Description)" class="text-danger" />
                        </div>
                    </div>
                      
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">@(isEditMode ? "Update" : "Create")</button>
                </div>
        
            </EditForm>
        </div>
    </div>
</div>

@code {
    bool isloaded;
    bool isSubmitting;
    private bool isEditMode = false;
    private string submitMessage;
    // Initialize lists to avoid null reference issues in the UI
    private List<ProjectDTO> proposals = new();
    private List<ProponentsDTO> proponents = new();
    private List<StatusDTO> statuses = new();
    private List<LocationDTO> locations = new();
    private List<CategoryDTO> categories = new();
    private List<ProjectType> projectTypes;
    [SupplyParameterFromForm]
    private ProjectDTO Proposal { get; set; } = new()
    {
        Tracking = new TrackingDTO(),
        SelectedLocationIds = new List<Guid>()
    };
    private int pageSize = 10;
    private int currentPage = 1;
    private string searchQuery = string.Empty;
    private HashSet<string> SelectedLocationIds { get; set; } = new();

    private int totalPages => (int)Math.Ceiling(filteredProposals.Count / (double)pageSize);

    private List<ProjectDTO> filteredProposals => proposals?
    .Where(p =>
        string.IsNullOrWhiteSpace(searchQuery) ||
        p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
    .ToList() ?? new();


    private List<ProjectDTO> pagedProposals =>
        filteredProposals
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();

    private void OnPageSizeChanged()
    {
        currentPage = 1;
        StateHasChanged();
    }

    protected override string PageSlug
    {
        get
        {
            var relativePath = navigationManager.ToBaseRelativePath(navigationManager.Uri);
            var firstSegment = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
            return (firstSegment ?? string.Empty).ToLowerInvariant();
        }
    }

    string GetSearchColClass()
    {
        return (CanExport, CanCreate) switch
        {
            (true, true) => "col-md-6",   // 6 + 2 + 2 + 2 = 12
            (true, false) => "col-md-8",   // 8 + 2 + 2     = 12
            (false, true) => "col-md-8",   // 8 + 2 + 2     = 12
            (false, false) => "col-md-10",  // 10 + 2        = 12
        };
    }

    protected override async Task OnPageInitializedAsync()
    {

        await JSRuntime.InvokeVoidAsync("Spinner.show");
        try
        {
            var statusResult = await StatusService.GetStatusAsync();
            statuses = (statusResult ?? new List<StatusDTO>()).Where(s => s.Category == Category.Brief).ToList();

            // Fetch projects and proponents with null-checks to prevent null assignments
            var projectResult = await ProjectService.GetProjectAsync(true);
            proposals = projectResult ?? new List<ProjectDTO>();

            var proponentResult = await ProponentService.GetProponentsAsync();
            proponents = proponentResult ?? new List<ProponentsDTO>();

            var locationsResult = await LocationService.GetLocationsAsync();
            locations = locationsResult ?? new List<LocationDTO>();

            var categoriesResult = await CategoryService.GetCategories();
            categories = categoriesResult ?? new List<CategoryDTO>();

            isloaded = true;
        }
        catch (Exception ex)
        {

        }
        finally
        {
            await Task.Delay(200);
            await JSRuntime.InvokeVoidAsync("Spinner.hide");
        }

    }

    async Task HandleSubmission()
    {
        isSubmitting = true;
        try
        {
            if (!Proposal.SelectedLocationIds.Any())
            {
                return; // stop if nothing selected
            }

            Proposal.SelectedLocationIds.ToList();
            Proposal.createdOn = DateTime.Now;
            Proposal.ProjectType = ProjectType.Brief;
            Proposal.closingDate = DateTime.Now;
            Proposal.assignedDate = DateTime.Now;
            var response = await ProjectService.CreateProjectAsync(Proposal);
            if (response.IsSuccessStatusCode)
            {

                await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");

                await JSRuntime.InvokeVoidAsync("SwalService.success", "Added a Brief Successfull.");

                Proposal = new ProjectDTO();
            }
            // await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");
        }
        catch(Exception ex)
        {
            submitMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            var projectResult = await ProjectService.GetProjectAsync(true);
            proposals = projectResult ?? new List<ProjectDTO>();

            var proponentResult = await ProponentService.GetProponentsAsync();
            proponents = proponentResult ?? new List<ProponentsDTO>();
            StateHasChanged();
        }

    }

    async Task HandleUpdate(){

        isSubmitting = true;
        submitMessage = null;
        try
        {
            var selectedStatus = statuses.FirstOrDefault(s => s.ID == Proposal?.Tracking?.StatusID);

            if (selectedStatus?.Name == "Collected" && Proposal.ProjectType == ProjectType.Brief)
            {
                submitMessage = "Approved a Project Brief must be assigned a valid project type.";
                return;
            }
            Proposal.SelectedLocationIds.ToList();
            // EditPerson.ProponentID = ;
            // Proponent!.ProponentID = Guid.Parse(PropID);
            Proposal.updatedOn = DateTime.Now;
            var response = await ProjectService.UpdateProjectAsync(Proposal.Id, Proposal);
            if (response.IsSuccessStatusCode)
            {
                // Refresh list
                proposals = await ProjectService.GetProjectAsync(true);

                // Reset form
                Proposal = new();

                // await JSRuntime.InvokeVoidAsync("closeModal", "staticBackdrop");
                // Close modal
                // await JSRuntime.InvokeVoidAsync("bootstrap.Modal.getInstance", modalElement).AsTask();
                isEditMode = false;
                // submitMessage = "Proposal updated successfully!"; 
                // await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");
                await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");

                await JSRuntime.InvokeVoidAsync("SwalService.success", "Project Brief updated successfully!");

            }
            else
            {
                submitMessage = $"Error {response.StatusCode}: {await response.Content.ReadAsStringAsync()}";
                return;
            }
        }
        catch (Exception ex)
        {
            submitMessage = $"Error: {ex.Message}";
        }
        finally
        {
            // submitMessage = null;
            isSubmitting = false;
            StateHasChanged();
        }
    }
    // add this field with other fields
    private List<ContactPersonDTO> contacts = new();

    // update editProposal method
    async Task editProposal(ProjectDTO project)
    {
        var tracking = project.Trackings?
            .OrderByDescending(t => t.createdOn)
            .FirstOrDefault();
        var selectedStatus = statuses.FirstOrDefault(s => s.ID == Proposal?.Tracking?.StatusID);

        if (selectedStatus?.Name == "Collected" && project.ProjectType == ProjectType.Brief)
        {
            submitMessage = "Approved Brief must be assigned a valid project type.";
            return;
        }

        var defaultStatusId = statuses.FirstOrDefault()?.ID ?? Guid.Empty;

        Proposal = new ProjectDTO()
        {
            Id = project.Id,
            Name = project.Name,
            ProponentID = project.ProponentID,
            ProjectType = project.ProjectType,
            Description = project.Description,
            SubmissionDate = project.SubmissionDate,
            createdOn = project.createdOn,
            CategoryID = project.CategoryID,
            Tracking = new TrackingDTO()
            {
                StatusID = tracking?.StatusID ?? defaultStatusId
            }
        };

        Proposal.SelectedLocationIds = project.ProjectLocations?.Select(i => i.LocationID).ToList();

        var statusResult = await StatusService.GetStatusAsync();
        statuses = (statusResult ?? new List<StatusDTO>()).OrderBy(s => s.SortOrder).Take(3).ToList();

        // fetch contact persons for this project (await the task so 'contacts' is a List, not a Task)
        var contactsResult = await ContactPersonService.GetContactPersonsAsync(project.ProponentID);
        contacts = contactsResult ?? new List<ContactPersonDTO>();

        isEditMode = true;

        await JSRuntime.InvokeVoidAsync("showModal", "staticBackdrop");
    }
    private Timer? _debounce;

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? string.Empty;
        currentPage = 1; // reset to first page on new search
        _debounce?.Dispose();
        _debounce = new Timer(_ => InvokeAsync(StateHasChanged), null, 400, Timeout.Infinite);
    }

    async Task createExcel()
    {
        var bytes = await ProjectService.ExportProjectAsync(ProjectType.Brief, searchQuery);
        await JSRuntime.InvokeVoidAsync("downloadFile",
            $"Briefs_{DateTime.Now:yyyyMMdd}.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            bytes);
    }

    async Task createPDF()
    {
        var bytes = await ProjectService.ExportProjectPDFAsync(ProjectType.Brief, searchQuery);
        await JSRuntime.InvokeVoidAsync("downloadFile",
            $"Projects_{DateTime.Now:yyyyMMdd}.pdf",
            "application/pdf",
            bytes);
    }


}
