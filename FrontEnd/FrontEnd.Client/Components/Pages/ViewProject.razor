                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="exampleFormControlInput1" class="form-label">Proponent Name</label>
                        <input type="text" class="form-control" id="exampleFormControlInput1" placeholder="Enter Proponent Name." required>
                    </div>
                    <div class="mb-3">
                        <label for="exampleFormControlInput1" class="form-label">Postal Address</label>
                        <input type="text" class="form-control" id="exampleFormControlInput1" placeholder="Enter Proponent Postal Address." required>
                    </div>
                    <div class="mb-3">
                        <label for="exampleFormControlInput1" class="form-label">Proponet Location</label>
                        <input type="text" class="form-control" id="exampleFormControlInput1" placeholder="Enter Proponent Location." required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary">Create</button>
                </div>
            </div>
        </div>
    </div>
}
<style>
    .planning-timeline {
        position: relative;
        margin-left: 0.5rem;
    }

    .timeline-item {
        position: relative;
        padding-left: 2rem;
    }

        .timeline-item::before {
            content: "";
            position: absolute;
            left: 0.47rem;
            top: 0.9rem;
            bottom: -0.5rem;
            width: 2px;
            background: #cfe2ff;
        }

        .timeline-item:last-child::before {
            bottom: 1.5rem;
        }

    .timeline-dot {
        position: absolute;
        left: 0;
        top: 0.7rem;
        width: 1rem;
        height: 1rem;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #0d6efd;
        box-shadow: 0 0 0 3px #e7f1ff;
    }

    .timeline-content .card {
        border-radius: 0.5rem;
    }

</style>

@code {
    [Parameter]
    public string? ProjectID { get; set; }

    public ProjectDTO? Project;
    
    private string TruncateToWords(string text, int wordLimit)
    {
        if (string.IsNullOrEmpty(text)) return text;

        var words = text.Split(' ');
        if (words.Length <= wordLimit) return text;

        return string.Join(" ", words.Take(wordLimit)) + "...";
    }

    protected override async Task OnInitializedAsync()
    {
        if (Guid.TryParse(ProjectID, out var projectId))
        {
            Project = await ProjectService.GetProjectAsync(projectId);
        }
    }

}
