                            : "—")
                                        </h6>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 my-2 ">
                            <div class="d-flex gap-4">
                                @* <i class="bi bi-building-fill"></i> *@
                                @* <i class="bi bi-geo-alt-fill fs-5 me-2"></i> *@
                                <i class="bi bi-stars fs-5 me-2"></i>
                                @* <i class="bi bi-mailbox2-flag fs-5 me-2"></i> *@
                                <div>
                                    <span class="mb-1">Project Status</span>
                                    @{ var latestStatus = Project?.Trackings?
                                        .OrderByDescending(t => t.createdOn)
                                        .FirstOrDefault()?.Status?.Name ?? "No status"; }
                                    <div><h6>@latestStatus</h6></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 my-2">
                            <div class="d-flex gap-4">
                                @* <i class="bi bi-building-fill"></i> *@
                                @* <i class="bi bi-geo-alt-fill fs-5 me-2"></i> *@
                                <i class="bi bi-person-badge fs-5 me-2"></i>
                                <div>
                                    <h6 class="mb-1">Reviewer Name</h6>
                                    <div><span>John Doe</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 my-2  border-start border-end">
                            <div class="d-flex gap-4">
                                @* <i class="bi bi-building-fill"></i> *@
                                <i class="bi bi-calendar-check-fill fs-5 me-2"></i>
                                <div>
                                    <span class="mb-1">Submission Date</span>
                                    <div><h6>@Project?.Proponent?.Name</h6></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 my-2">
                            <div class="d-flex gap-4">
                                @* <i class="bi bi-building-fill"></i> *@
                                @* <i class="bi bi-geo-alt-fill fs-5 me-2"></i> *@
                                @* <i class="bi bi-mailbox2-flag"></i> *@
                                <i class="bi bi-calendar-x-fill fs-5 me-2"></i>
                                <div>
                                    <span class="mb-1">Date Created</span>
                                    <div><h6>@Project.createdOn.ToString("dd MMMM yyyy")</h6></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 my-2">
                            <div class="d-flex gap-4">
                                @* <i class="bi bi-calendar-x-fill"></i> *@
                                <i class="bi bi-card-text fs-5 me-2"></i>
                                <div>
                                    <h6 class="mb-1">Description</h6>
                                    <div><p>@Project.Description</p></div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="border-top px-2">
                    @* <div class="my-2 row">
                        <div class="col-md-12">
                            <h5>Proponent Details</h5>
                        </div>
                        <div class="col-md-4 my-2">
                            <div class="d-flex gap-4">
                                <i class="bi bi-building-fill fs-5 me-2"></i>
                                <div>
                                    <h6 class="mb-1">Proponent Name</h6>
                                    <div><span>Mota-Engil</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 my-2 border-start border-end">
                            <div class="d-flex gap-4">
                                <i class="bi bi-mailbox2-flag fs-5 me-2"></i>
                                <div>
                                    <h6 class="mb-1">Proponent Address</h6>
                                    <div><span>Address</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 my-2">
                            <div class="d-flex gap-4">
                                <i class="bi bi-geo-alt-fill fs-5 me-2"></i>
                                <div>
                                    <h6 class="mb-1">Proponent Location</h6>
                                    <div><span>Location</span></div>
                                </div>
                            </div>
                        </div>
                    </div> *@
                    @{
                        ProponentsDTO Proponent = Project.Proponent;
                       } 
                       @if (Proponent != null)
                    {
                        <div class="my-2 row">
                            <div class="col-md-12">
                                <h5>Proponent Details</h5>
                            </div>
                            <div class="col-md-4 my-2">
                                <div class="d-flex gap-4">
                                    <i class="bi bi-building-fill fs-5 me-2"></i>
                                    <div>
                                        <small class="mb-1 fs-6">Proponent Name</small>
                                        <h6>@Proponent?.Name</h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 my-2 border-start border-end">
                                <div class="d-flex gap-4">
                                    @* <i class="bi bi-building-fill"></i> *@
                                    @* <i class="bi bi-geo-alt-fill fs-5 me-2"></i> *@
                                    <i class="bi bi-mailbox2-flag fs-5 me-2"></i>
                                    <div>
                                        <small class="mb-1 fs-6">Proponent Address</small>
                                        <h6>@Proponent?.Address</h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 my-2">
                                <div class="d-flex gap-4">
                                    @* <i class="bi bi-building-fill"></i> *@
                                    <i class="bi bi-geo-alt-fill fs-5 me-2"></i>
                                    <div>
                                        <small class="mb-1  fs-6">Proponent Location</small>
                                        <h6>@Proponent?.Location</h6>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>
            <div class="tab-pane fade" id="projects-tab-pane" role="tabpanel" aria-labelledby="projects-tab" tabindex="0">
                <div class="container py-4">
                    <div class="row ">
                        <div class="col-md-6">
                            <h5 class="fw-semibold mb-2">Project Timelines</h5>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3 input-group">
                                <span class="input-group-text" id="basic-addon1">Search</span>
                            <input type="search" class="form-control" placeholder="Search"
                                   value="@searchQuery"
                                   @oninput="OnSearchChanged" />
                                   </div>
                        </div>
                    </div>
                    @{
                        var trackings = (Project?.Trackings?.Where(i =>
    string.IsNullOrWhiteSpace(searchQuery) ||
    (i.Status?.Name?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
    (i.User?.FirstName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
    (i.User?.Surname?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
    (i.Review?.Remarks?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)
).ToList() ?? new List<TrackingDTO>())
.OrderByDescending(t => t.createdOn)
.ToList();
                    }

                    @if (trackings.Any())
                    {
                        @for (int i = 0; i < trackings.Count; i++)
                        {
                            var tracking = trackings[i];

                            <div class="planning-timeline">
                                <div class="timeline-item pb-4 pt-2">
                                    <div class="timeline-dot"></div>
                                    <div class="timeline-content">

                                        <div class="text-muted small mb-2">
                                            <i class="bi bi-calendar-event-fill me-1"></i>
                                            @tracking.createdOn.ToString("dd MMM yyyy")

                                            <span class="ms-2">
                                                <i class="bi bi-clock-fill me-1"></i>
                                                @tracking.createdOn.ToString("hh:mm tt")
                                            </span>

                                        </div>

                                        <div class="card border-0 bg-body-tertiary">
                                            <div class="card-body">
                                                <div class="d-flex align-items-center gap-2 mb-2">
    <span class="fw-semibold text-primary">
        @(tracking?.Status?.Category != Category.Brief
            ? Project?.ProjectType.ToString()
            : $"{Category.Brief} | {tracking?.Status?.Name}")
    </span>
    @if (i < trackings.Count - 1 && trackings[i + 1]?.Status?.Name == tracking?.Status?.Name)
    {
<span class="badge" style="font-size:0.7rem; background-color:#cff4fc; color:#055160; border: 1px solid #9eeaf9;">
    Updated
</span>
    }
</div>
                                                <div class="row g-3">
                                                    <div class="col-md-4">
                                                        <div class="text-muted small"><i class="bi bi-stars me-1"></i>Status</div>
                                                        <div class="fw-medium">
                                                            <StatusItem Name="@tracking?.Status?.Name" Colour="@tracking?.Status?.Color"></StatusItem>
                                                        </div>
                                                    </div>
                                                    @if (tracking?.User != null)
                                                    {
                                                        <div class="col-md-4">
                                                            <div class="text-muted small"><i class="bi bi-person-badge-fill me-1"></i>Reviewer Name</div>
                                                            <div class="fw-medium">@tracking.User.FirstName @tracking.User.Surname</div>
                                                        </div>
                                                    }
                                                    @if (tracking?.Review?.Remarks != null)
                                                    {
                                                        <div class="col-md-4">
                                                            <div class="text-muted small"><i class="bi bi-chat-square-dots-fill me-1"></i>Review</div>
                                                            <span class="d-inline-block text-truncate" style="max-width: 200px;">@tracking?.Review?.Remarks</span>
                                                            <br />
                                                            <NavLink type="button" @onclick="() => viewReview(tracking?.Review)" class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#staticBackdrop">View</NavLink>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    @if (i < trackings.Count - 1)
                                    {
                                        var diff = tracking.createdOn - trackings[i + 1].createdOn;
                                        <div class="small text-success pt-2">
                                            <i class="bi bi-arrow-down"></i>
                                            Duration: @diff.Humanize(2)
                                        </div>
                                    }
                                </div>

                            </div>
                        }
                    }
                </div>


                @* </div> *@

            </div>
            @* <div class="tab-pane fade" id="contact-tab-pane" role="tabpanel" aria-labelledby="contact-tab" tabindex="0">...</div>
        <div class="tab-pane fade" id="disabled-tab-pane" role="tabpanel" aria-labelledby="disabled-tab" tabindex="0">...</div> *@
        </div>
        <div class="p-2 bg-white rounded-bottom  border-start border-end border-bottom">
            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => GoBack()">Back</button>
            <NavLink class="btn btn-outline-secondary btn-sm" href=@($"/Proponent/View/{Project?.ProponentID}")>Proponent</NavLink>
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#staticBackdrop">Add Review</button>
        </div>
    </div>

    <div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
            <EditForm method="post" Model="Proponent" OnValidSubmit="AddReview" FormName="create">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="staticBackdropLabel">Add Review</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="exampleFormControlInput1" class="form-label">Remarks</label>
                        <InputTextArea id="Remarks" @bind-Value="Review.Remarks" class="form-control" placeholder="Enter Review Remarks." rows="4" />
                        <ValidationMessage For="@(() => Review.Remarks)" class="text-danger" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromForm]
    private ReviewDTO? Review { get; set; } = new();

    [Parameter]
    public string? ProjectID { get; set; }

    public ProjectDTO? Project;
    private string searchQuery = string.Empty;

    public List<TrackingDTO> filteredTrack = new();

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? string.Empty;
        // currentPage = 1; reset to first page on new search
        _debounce?.Dispose();
        _debounce = new Timer(_ => InvokeAsync(StateHasChanged), null, 400, Timeout.Infinite);
    }

    private Timer? _debounce;

    private string TruncateToWords(string text, int wordLimit)
    {
        if (string.IsNullOrEmpty(text)) return text;

        var words = text.Split(' ');
        if (words.Length <= wordLimit) return text;

        return string.Join(" ", words.Take(wordLimit)) + "...";
    }

    protected override async Task OnInitializedAsync()
    {
        await JSRuntime.InvokeVoidAsync("Spinner.show");
        try
        {
            if (Guid.TryParse(ProjectID, out var projectId))
            {
                Project = await ProjectService.GetProjectAsync(projectId);
                // filteredTrack = 
            }
        }
        catch (Exception ex)
        {

        }
        finally
        {
            await JSRuntime.InvokeVoidAsync("Spinner.hide");
        }

    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("Navigation.back");
    }

    async Task AddReview()
    {
        if (Project != null && Review != null)
        {
            if (Guid.TryParse(ProjectID, out var projectId))
            {
                Review.ProjectID = Guid.Parse(ProjectID);
                await ReviewService.CreateReviewAsync(Review);
                Project = await ProjectService.GetProjectAsync(projectId);
                await JSRuntime.InvokeVoidAsync("hideModal", "staticBackdrop");
       
                await JSRuntime.InvokeVoidAsync("SwalService.success", "Added a Project Remark.");
         
            }
        }
    }

    async Task viewReview(ReviewDTO review)
    {
        Review.Remarks = review.Remarks;
        Review.ProjectID = review.ProjectID;
        Review.TrackingID = review.TrackingID;
    }

}
