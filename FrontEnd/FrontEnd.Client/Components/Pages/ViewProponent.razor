@code {
    private ProponentsDTO? Proponent;

    [SupplyParameterFromForm]
    private ContactPersonDTO ContactPerson { get; set; } = new();

    [Parameter]
    public string? PropID { get; set; }

    public string? submitMessage { get; set; }

    public bool isSubmitting { get; set; }

    private List<ContactPersonDTO>? contactPeople; 

    private string TruncateToWords(string text, int wordLimit)
    {
        if (string.IsNullOrEmpty(text)) return text;

        var words = text.Split(' ');
        if (words.Length <= wordLimit) return text;

        return string.Join(" ", words.Take(wordLimit)) + "...";
    }

    protected override async Task OnInitializedAsync()
    {
        // var proponentID = Guid.
        // if (!string.IsNullOrEmpty(PropID))
        // {
            Proponent = await ProponentService.GetProponentAsync(
            Guid.Parse(PropID));
            contactPeople = await ContactPersonService.GetContactPersonsAsync(Guid.Parse(PropID));
        // }
    }

    protected async Task HandleSubmission()
    {
        isSubmitting = true;
        submitMessage = null;
        try
        {
            ContactPerson.ProponentID = Guid.Parse(PropID);
            ContactPerson.createdOn = DateTime.Now;
            var response = await ContactPersonService.CreateContactPersonAsync(ContactPerson);
            if (response.IsSuccessStatusCode)
            {
                // Refresh list
                contactPeople = await ContactPersonService.GetContactPersonsAsync(Guid.Parse(PropID));
                // Reset form
                Proponent = new();
                // Close modal
                // await JSRuntime.InvokeVoidAsync("bootstrap.Modal.getInstance", modalElement).AsTask();
                submitMessage = "Proponent created successfully!";
            }
            else
            {
                submitMessage = $"Error {response.StatusCode}: {await response.Content.ReadAsStringAsync()}";
            }
        }
        catch (Exception ex)
        {
            submitMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }
}
