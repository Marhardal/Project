@namespace FrontEnd.Components

<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(FrontEnd.Client._Imports).Assembly }"
        NotFoundPage="typeof(FrontEnd.Components.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(FrontEnd.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
